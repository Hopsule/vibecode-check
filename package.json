{
  "name": "vibechecker",
  "version": "0.2.0",
  "description": "Your React code's health check-up. One command. Zero config. Actually fixes your code.",
  "bin": {
    "vibechecker": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "npm run build && node --test tests/scanner.test.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "react",
    "lint",
    "code-health",
    "cli",
    "autofix",
    "next.js",
    "static-analysis",
    "code-quality",
    "vibe-check",
    "vibe-coding",
    "ai-friendly"
  ],
  "license": "MIT",
  "homepage": "https://github.com/Hopsule/vibechecker#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hopsule/vibechecker.git"
  },
  "bugs": {
    "url": "https://github.com/Hopsule/vibechecker/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@typescript-eslint/typescript-estree": "^8.0.0",
    "chokidar": "^4.0.0",
    "commander": "^12.0.0",
    "fast-glob": "^3.0.0",
    "picocolors": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
